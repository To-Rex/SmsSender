<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".ui.dashboard.DashboardFragment">

    <!-- Header Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_gradient"
        android:elevation="4dp"
        android:orientation="horizontal"
        android:padding="20dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:alpha="0.7"
            android:src="@drawable/history_icon"
            tools:ignore="ContentDescription" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Yuborilgan SMSlar"
                android:textColor="#99FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08" />

            <TextView
                android:id="@+id/textView4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/jo_natilgan_smslar"
                android:textColor="@color/white"
                android:textSize="17sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- List Container -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:layout_weight="1"
        android:background="@drawable/bg_card_white"
        android:elevation="2dp"
        android:padding="8dp">

        <ListView
            android:id="@+id/dashList"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:divider="@null"
            android:padding="4dp"
            android:scrollbars="none" />
    </FrameLayout>

    <!-- Bottom Button -->
    <Button
        android:id="@+id/btnDashRefresh"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/bg_button_outline"
        android:elevation="2dp"
        android:gravity="center"
        android:text="@string/yuborilgan_smslarni_tozalash"
        android:textAllCaps="false"
        android:textColor="@color/color5"
        android:textSize="14sp"
        android:textStyle="bold"
        tools:ignore="TextViewEdits" />

</LinearLayout>
