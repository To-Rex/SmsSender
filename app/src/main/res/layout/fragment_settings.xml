<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".ui.settings.SettingsFragment">

    <!-- Qo'llanma -->
    <LinearLayout
        android:id="@+id/guideCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_card_white"
        android:elevation="2dp"
        android:orientation="vertical"
        android:padding="16dp"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:id="@+id/guideHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Qo'llanma"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/guideArrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="4dp"
                android:text="▼"
                android:textColor="@color/label_text"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/guideContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:visibility="gone">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:text="IP manzil qo'shish:\n1. IP manzilni quyidagicha kiriting: http://yourserver.com/\n2. Agar lokal server bo'lsa, localhost yozish kifoya — avtomatik router IP bilan almashtiriladi\n3. http:// yoki https:// bilan boshlanishi shart\n4. + tugmasini bosing\n\nIP manzilni faollashtirish/o'chirish:\n• Yashil — faol IP (shu manzilga so'rov yuboriladi)\n• Oq — nofaol IP\n• Bosib turib faollashtirish/to'xtatish mumkin\n\nTelefon raqam:\n• +998 formatida kiritiladi (9 ta raqam)\n• Kiritilgach avtomatik yashirinadi\n\nSMS limiti:\n• Minimal 50 ta, maksimal 5000 ta\n• Limit tugagach yangi SMS jo'natilmaydi\n\nOvoz sozlamalari:\n• SMS ovozi: 3 rejim — ovoz / vibratsiya / o'chirish\n• Yakunlash ovozi: ovoz bor / yo'q" />

        </LinearLayout>
    </LinearLayout>

    <!-- SECTION 1: SMS Configuration -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_white"
        android:elevation="2dp"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SMS Sozlamalari"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="4dp"
            android:background="@color/divider" />

        <!-- SMS Limit Row -->
        <LinearLayout
            android:id="@+id/txtSetIpAdressWrapper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="12dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:alpha="0.5"
                android:src="@drawable/sms_dash"
                tools:ignore="ContentDescription" />

            <TextView
                android:id="@+id/txtSetIpAdress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:paddingVertical="4dp"
                android:text="@string/sms_limt"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:alpha="0.3"
                android:src="@drawable/baseline_add"
                tools:ignore="ContentDescription" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider" />

        <!-- Phone Row -->
        <LinearLayout
            android:id="@+id/txtSetPhoneWrapper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="12dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:alpha="0.5"
                android:src="@drawable/kontakt_icon"
                tools:ignore="ContentDescription" />

            <TextView
                android:id="@+id/txtSetPhone"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:paddingVertical="4dp"
                android:text="@string/phone"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:alpha="0.3"
                android:src="@drawable/baseline_add"
                tools:ignore="ContentDescription" />
        </LinearLayout>

        <!-- Phone Input (hidden when phone is set) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtSetphoneId"
                android:layout_width="wrap_content"
                android:layout_height="46dp"
                android:background="@drawable/bg_header_gradient"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/_998"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/ediSetPhone"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_marginStart="2dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_white"
                android:elevation="1dp"
                android:hint="@string/telefon_raqam"
                android:inputType="phone"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                tools:ignore="Autofill" />

            <ImageView
                android:id="@+id/btnSetAddPhone"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_button_teal"
                android:elevation="2dp"
                android:padding="12dp"
                android:src="@drawable/baseline_add"
                tools:ignore="ContentDescription" />
        </LinearLayout>
    </LinearLayout>

    <!-- SECTION 2: IP Address Input -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_card_white"
        android:elevation="2dp"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="IP Manzillar"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/ediSetIpAdress"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_white"
                android:elevation="1dp"
                android:hint="@string/yangi_ip_manzil"
                android:inputType="textUri"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                tools:ignore="Autofill" />

            <ImageView
                android:id="@+id/btnSetAdd"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_button_teal"
                android:elevation="2dp"
                android:padding="12dp"
                android:src="@drawable/baseline_add"
                tools:ignore="ContentDescription" />
        </LinearLayout>
    </LinearLayout>

    <!-- IP List -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:background="@drawable/bg_card_white"
        android:elevation="2dp"
        android:padding="8dp">

        <ListView
            android:id="@+id/listSettings"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:divider="@null"
            android:padding="4dp"
            android:scrollbars="none" />
    </FrameLayout>

    <!-- Hidden view for layout compatibility -->
    <View
        android:id="@+id/view"
        android:layout_width="0dp"
        android:layout_height="0dp" />

    <!-- SECTION 3: Sound & Vibration -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_card_white"
        android:elevation="2dp"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ovoz va Vibratsiya"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="4dp"
            android:background="@color/divider" />

        <!-- SMS Sound Toggle -->
        <LinearLayout
            android:id="@+id/imgSetSoundWrapper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="8dp">

            <ImageView
                android:id="@+id/imgSetSound"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:padding="4dp"
                android:src="@drawable/sound_on"
                tools:ignore="ContentDescription" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="SMS jo'natish ovozi"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider" />

        <!-- Completion Sound Toggle -->
        <LinearLayout
            android:id="@+id/imgSetSoundsWrapper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="8dp">

            <ImageView
                android:id="@+id/imgSetSounds"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:padding="4dp"
                android:src="@drawable/sound_1"
                tools:ignore="ContentDescription" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Yakunlash ovozi"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
